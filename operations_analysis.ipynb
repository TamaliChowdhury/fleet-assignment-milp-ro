  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "22594fb4-0c41-4d58-a1c6-157f99edf7a9",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
