  "def calculate_regret(assignment, scenario_costs, optimal_costs):\n",
  "    \"\"\"Calculates the deviation from the deterministic optimum per scenario.\"\"\"\n",
  "    regrets = []\n",
  "    for s in scenarios:\n",
  "        regret = scenario_costs[s][assignment] - optimal_costs[s]\n",
  "        regrets.append(regret)\n",
  "    return max(regrets)\n",
  "\n",
  "# Solve for the Minimax Regret Committed Plan\n",
  "best_regret = float('inf')\n",
  "committed_plan = None\n",
  "\n",
  "for plan in candidate_plans:\n",
  "    max_r = calculate_regret(plan, scenario_costs, optimal_costs)\n",
  "    if max_r < best_regret:\n",
  "        best_regret = max_r\n",
  "        committed_plan = plan\n",
  "\n",
  "print(f\"Minimax Regret Value: v = {best_regret}\")"
 ]
}
